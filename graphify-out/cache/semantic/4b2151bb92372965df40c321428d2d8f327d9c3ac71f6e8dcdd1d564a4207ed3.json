{"nodes": [{"id": "stock_market_trend_analysis_claude_architecture", "label": "CLAUDE.md \u2014 Architecture Reference", "file_type": "document", "source_file": "Stock-Market-Trend-Analysis/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Ali Agela", "contributor": null}, {"id": "stock_market_trend_analysis_claude_leakage_prevention_invariants", "label": "Leakage-Prevention Invariants", "file_type": "rationale", "source_file": "Stock-Market-Trend-Analysis/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The whole project rests on six guards: next-day target built per split, shift(1)-before-rolling on all rolling/lag features, expanding past-only target encoding, fit-on-train-only scaler/models, holdout opened exactly once, and ticker-scoped exogenous ffill. Agent audits caught real leaks (off-by-one target, global-mean encoding)."}, {"id": "stock_market_trend_analysis_claude_multi_agent_audit", "label": "Multi-Agent Adversarial Audit", "file_type": "rationale", "source_file": "Stock-Market-Trend-Analysis/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each milestone is reviewed in parallel by independent expert subagents (Investment Researcher, Model QA Specialist, Data Engineer on M1) who reproduce every headline number before flagging by severity. They caught real BLOCKERs: next-day off-by-one target, global-mean encoding leakage, vacuous sealing check, ARIMA one-step off-by-one, EGARCH mislabel."}], "edges": [{"source": "stock_market_trend_analysis_claude_architecture", "target": "stock_market_trend_analysis_claude_leakage_prevention_invariants", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Stock-Market-Trend-Analysis/CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "stock_market_trend_analysis_claude_a